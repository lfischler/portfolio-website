---
layout: "base.njk"
wide: true
---

<article class="article">

  <p class="crumb">
    <a href="/projects/" class="under">Projects</a> &nbsp;/&nbsp; {{ title }}
  </p>

  <h1 class="heading">{{ title }}</h1>

  {% if summary %}
  <p class="summary">{{ summary | safe }}</p>
  {% endif %}

  <div class="meta-block">

    {% if year %}
      <span class="k">Year</span>
      <span class="v">{{ yearDisplay or year }}</span>
    {% endif %}

    {% if kind %}
      <span class="k">Kind</span>
      <span class="v">{{ kind }}</span>
    {% endif %}

    {% if skills %}
      <span class="k">Skills</span>
      <span class="v"><em>{{ skills }}</em></span>
    {% endif %}

    {% if tech and tech.length %}
      <span class="k">Tags</span>
      <span class="v tags">
        {%- for t in tech -%}<span>{{ t }}</span>{%- endfor -%}
      </span>
    {% endif %}

    {% if collaborators %}
      <span class="k">With</span>
      <span class="v">{{ collaborators }}</span>
    {% endif %}

    {% if siteUrl %}
      <span class="k">Visit</span>
      <span class="v"><a href="{{ siteUrl }}" class="under">{{ siteUrl | replace("https://", "") | replace("http://", "") | truncate(50) }}</a></span>
    {% endif %}

    {% if repoUrl %}
      <span class="k">Code</span>
      <span class="v"><a href="{{ repoUrl }}" class="under">{{ repoUrl | replace("https://", "") | replace("http://", "") | truncate(50) }}</a></span>
    {% endif %}

  </div>

  <div class="prose">
    {{ content | safe }}
  </div>

</article>
